// Prisma schema for initial models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Module {
  id           String   @id @default(cuid())
  name         String
  description  String
  author       String
  version      String
  status       String   @default("Pending")
  submittedAt  DateTime @default(now())
  categories   Category[] @relation("ModuleCategories", references: [id], fields: [])
  cooldownTime Int?
  cooldownUnit String?
  cooldownScope String?
  maxPlayers   Int?
  playerTagName String?
}

model Server {
  id String @id @default(cuid())
  name String
  description String?
  modules Module[] @relation("ServerModules")
  createdAt DateTime @default(now())
}

model Category {
  id String @id @default(cuid())
  name String
  color String?
  modules Module[] @relation("ModuleCategories")
}

model ServerModulePlayer {
  id String @id @default(cuid())
  server Server @relation(fields: [serverId], references: [id])
  serverId String
  module Module @relation(fields: [moduleId], references: [id])
  moduleId String
  currentPlayers Int @default(0)
}
